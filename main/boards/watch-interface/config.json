{
    "target": "esp32s3",
    "builds": [
        {
            "name": "watch-interface",
            "sdkconfig_append": [
                "CONFIG_BOARD_TYPE_WATCH_INTERFACE=y",
                "CONFIG_LANGUAGE_VI_VN=y",
                "CONFIG_LCD_ILI9341_240X320=y",
                "CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y",
                "CONFIG_ESPTOOLPY_FLASHSIZE=\"8MB\"",
                "CONFIG_PARTITION_TABLE_CUSTOM_FILENAME=\"partitions/v2/8m.csv\"",
                "CONFIG_PARTITION_TABLE_FILENAME=\"partitions/v2/8m.csv\"",
                "CONFIG_FLASH_DEFAULT_ASSETS=y",
                "CONFIG_USE_AFE_WAKE_WORD=y",
                "CONFIG_SR_WN_WN9_HIJOY_TTS=y",
                "CONFIG_SPIRAM=y",
                "CONFIG_SPIRAM_MODE_QUAD=y",
                "# CONFIG_SPIRAM_MODE_OCT is not set",
                "CONFIG_SPIRAM_SPEED_80M=y",
                "CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=2048",
                "CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=98304",
                "CONFIG_SPIRAM_MEMTEST=n"
            ]
        }
    ]
}
